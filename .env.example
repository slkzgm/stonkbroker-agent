# Robinhood Chain mainnet
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
STONKBROKER_NFT_ADDRESS=0x539CdD042c2f3d93EbC5BE7DfFf0c79F3B4fAbF0
BROKER_TOKEN_ID=1

# Required only for quotes and live trades
UNISWAP_API_KEY=

# Required only for live trades. This must be the private key of the current
# owner of BROKER_TOKEN_ID. Never commit it.
OWNER_PRIVATE_KEY=
ALLOW_LIVE_TRADING=false
# Maximum percentage of the input-token balance per trade (500 = 5%).
MAX_TRADE_BPS=500

# OAuth 2.0 user access token with tweet.read, tweet.write, and users.read
# (not an app-only bearer token).
# Live trading is refused when REQUIRE_X_POST=true and this token is missing.
X_USER_ACCESS_TOKEN=
REQUIRE_X_POST=true
X_DRY_RUN=false

# Durable retry queue for posts after confirmed swaps.
OUTBOX_PATH=.stonkagent/outbox.json
POST_RETRY_INTERVAL_MS=60000
